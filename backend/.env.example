HOST=127.0.0.1
PORT=3500
AUTH_TOKEN=change-me-to-random-64-char-string
AUTH_TOKEN_MIN_LENGTH=24
CREDENTIAL_ENCRYPTION_KEY=change-me-to-different-random-64-char-string
# Omit CREDENTIAL_ENCRYPTION_KEY to use the generated git-ignored data/.credential-key file.
# Undecryptable legacy credentials are preserved; affected bot accounts start disabled until credentials are re-entered.
CORS_ORIGIN=http://localhost:5200

PAPER_INITIAL_BALANCE=10000
PAPER_SLIPPAGE=0.05
PAPER_MAKER_FEE=0.02
PAPER_TAKER_FEE=0.055

BYBIT_TESTNET=false
BYBIT_REST_BASE_URL=https://api.bybit.com
BYBIT_DEMO_REST_BASE_URL=https://api-demo.bybit.com
BYBIT_POSITION_MODE=oneway
BYBIT_PRIVATE_RATE_LIMIT_DELAY_MS=500

ENABLE_PRICE_UPDATER=true
AUTO_START_BOTS=false
AUTO_START_OPTIMIZER=false
AUTO_START_TELEGRAM_CLIENT=false
AUTO_START_DELIST_CHECKER=false
AUTO_REPARSE_OLD_ALERTS=false
AUTO_START_REPLICAS=false
AUTO_START_REPLICA_COMPARE=false
AUTO_START_REPLICA_TUNER=false

# Optimizer heap budget is global across worker processes unless a per-worker override is set.
OPTIMIZER_HEAP_TOTAL_MAX_BARS=8000000
# OPTIMIZER_HEAP_MAX_BARS=1000000

TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=
TELEGRAM_CHANNEL_SNIPER=
TELEGRAM_CHANNEL_HAMMER=
TELEGRAM_CHANNEL_FR=
TELEGRAM_CHANNEL_M1A=
TELEGRAM_NOTIFY_BOT_TOKEN=
TELEGRAM_NOTIFY_CHAT_ID=
TELEGRAM_SEND_TIMEOUT_MS=10000

ANTHROPIC_API_KEY=
